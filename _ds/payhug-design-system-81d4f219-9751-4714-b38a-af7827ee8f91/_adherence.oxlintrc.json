{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/data/**",
              "components/feedback/**",
              "components/forms/**",
              "components/navigation/**",
              "ui_kits/admin_settlement/**",
              "ui_kits/payhug_app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Noto Sans KR|Inter))/i]",
        "message": "Font not provided by the design system. Available: Noto Sans KR, Inter."
      },
      {
        "selector": "JSXOpeningElement[name.name='AlertBanner'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|title|trailing|children|collapsible|defaultOpen|style|key|ref|className|style|children)$/]",
        "message": "<AlertBanner> doesn't accept that prop. Declared props: tone, title, trailing, children, collapsible, defaultOpen, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='AlertBanner'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:danger|warning|info|success)$/]",
        "message": "<AlertBanner> tone must be one of 'danger' | 'warning' | 'info' | 'success'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|name|size|tone|square|style|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: src, name, size, tone, square, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:green|navy|blue|neutral)$/]",
        "message": "<Avatar> tone must be one of 'green' | 'navy' | 'blue' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|variant|size|dot|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, variant, size, dot, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:soft|solid|outline)$/]",
        "message": "<Badge> variant must be one of 'soft' | 'solid' | 'outline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Badge> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|disabled|block|iconLeft|iconRight|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, disabled, block, iconLeft, iconRight, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|action|forest|secondary|ghost|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'action' | 'forest' | 'secondary' | 'ghost' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|pad|radius|shadow|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, tone, pad, radius, shadow, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:default|plain|danger|success|warning|blue|green)$/]",
        "message": "<Card> tone must be one of 'default' | 'plain' | 'danger' | 'success' | 'warning' | 'blue' | 'green'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|label|disabled|size|style|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: checked, onChange, label, disabled, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|error|prefix|suffix|size|disabled|style|inputStyle|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, hint, error, prefix, suffix, size, disabled, style, inputStyle."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Input> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SalesRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:issuer|amount|count|key|zero|sub|key|ref|className|style|children)$/]",
        "message": "<SalesRow> doesn't accept that prop. Declared props: issuer, amount, count, key, zero, sub."
      },
      {
        "selector": "JSXOpeningElement[name.name='CalendarDay'] > JSXAttribute > JSXIdentifier[name!=/^(?:card|delivery|key|ref|className|style|children)$/]",
        "message": "<CalendarDay> doesn't accept that prop. Declared props: card, delivery."
      },
      {
        "selector": "JSXOpeningElement[name.name='SegmentedTabs'] > JSXAttribute > JSXIdentifier[name!=/^(?:items|value|onChange|accent|size|style|key|ref|className|style|children)$/]",
        "message": "<SegmentedTabs> doesn't accept that prop. Declared props: items, value, onChange, accent, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SegmentedTabs'] > JSXAttribute[name.name='accent'] > Literal[value!=/^(?:blue|green)$/]",
        "message": "<SegmentedTabs> accent must be one of 'blue' | 'green'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SegmentedTabs'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<SegmentedTabs> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SelectOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<SelectOption> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='SidebarNavItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|icon|badge|key|ref|className|style|children)$/]",
        "message": "<SidebarNavItem> doesn't accept that prop. Declared props: value, label, icon, badge."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatTile'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|unit|sub|tone|align|size|style|key|ref|className|style|children)$/]",
        "message": "<StatTile> doesn't accept that prop. Declared props: label, value, unit, sub, tone, align, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatTile'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:default|pos|neg|blue|warning)$/]",
        "message": "<StatTile> tone must be one of 'default' | 'pos' | 'neg' | 'blue' | 'warning'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatTile'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|right)$/]",
        "message": "<StatTile> align must be one of 'left' | 'right'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatTile'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:md|lg)$/]",
        "message": "<StatTile> size must be one of 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|closable|key|ref|className|style|children)$/]",
        "message": "<TabItem> doesn't accept that prop. Declared props: value, label, closable."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
